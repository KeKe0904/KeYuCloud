    { "path": "pages/admin/smtp-templates", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
    { "path": "pages/admin/smtp-logs", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },

    { "path": "pages/admin/upstream", "style": { "navigationStyle": "custom" } },
    { "path": "pages/admin/smtp", "style": { "navigationStyle": "custom" } },
    { "path": "pages/admin/sms", "style": { "navigationStyle": "custom" } },
    { "path": "pages/admin/system", "style": { "navigationStyle": "custom" } }
