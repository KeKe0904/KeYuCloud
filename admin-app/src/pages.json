{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^ui-(.*)": "@/components/ui/$1.vue",
      "^ky-(.*)": "@/components/ky/$1.vue"
    }
  },
  "pages": [
    { "path": "pages/admin/login", "style": { "navigationStyle": "custom", "disableScroll": true } },

    { "path": "pages/dashboard/dashboard", "style": { "navigationStyle": "custom" } },
    { "path": "pages/users/users", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
    { "path": "pages/tickets/tickets", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
    { "path": "pages/finance/finance", "style": { "navigationStyle": "custom" } },
    { "path": "pages/profile/profile", "style": { "navigationStyle": "custom" } },

    { "path": "pages/admin/user-detail", "style": { "navigationStyle": "custom" } },
    { "path": "pages/admin/order-detail", "style": { "navigationStyle": "custom" } },
    { "path": "pages/admin/ticket-detail", "style": { "navigationStyle": "custom" } },

    { "path": "pages/admin/products", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
    { "path": "pages/admin/orders", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
    { "path": "pages/admin/user-products", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
    { "path": "pages/admin/coupons", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
    { "path": "pages/admin/announcements", "style": { "navigationStyle": "custom", "enablePullDownRefresh": true } },
