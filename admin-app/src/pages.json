  "tabBar": {
    "color": "#71717a",
    "selectedColor": "#18181b",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/dashboard/dashboard",
        "text": "仪表盘",
        "iconPath": "static/tab/house.png",
        "selectedIconPath": "static/tab/house-active.png"
      },
      {
        "pagePath": "pages/users/users",
        "text": "用户",
        "iconPath": "static/tab/user.png",
        "selectedIconPath": "static/tab/user-active.png"
      },
      {
        "pagePath": "pages/tickets/tickets",
        "text": "工单",
        "iconPath": "static/tab/message.png",
        "selectedIconPath": "static/tab/message-active.png"
      },
      {
        "pagePath": "pages/finance/finance",
        "text": "财务",
        "iconPath": "static/tab/box.png",
        "selectedIconPath": "static/tab/box-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "static/tab/grip.png",
        "selectedIconPath": "static/tab/grip-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "柯羽云",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f4f4f5",
