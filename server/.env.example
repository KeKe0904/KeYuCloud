# ============================================================================
# KeYuCloud 后端环境配置示例
# ----------------------------------------------------------------------------
# 使用方法：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 修改所有 "change-me" 占位符为真实值
#   3. 生产环境务必使用强随机密钥（可用 openssl rand -hex 32 生成）
# ============================================================================

# ===== 应用 =====
NODE_ENV=production
PORT=3001
# CORS 允许来源（多个用逗号分隔，生产环境应为你自己的域名）
CORS_ORIGIN=https://your-domain.com

# ===== MySQL 数据库 =====
# 格式：mysql://用户名:密码@主机:端口/数据库名?schema=public
# 密码中含特殊字符（@、:、/ 等）需 URL 编码，例如 @ → %40
DATABASE_URL="mysql://rainyun:your-strong-password@127.0.0.1:3306/rainyun_reseller?schema=public"
SHADOW_DATABASE_URL="mysql://rainyun:your-strong-password@127.0.0.1:3306/rainyun_reseller_shadow?schema=public"

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT 密钥（生产环境务必修改为强随机串）=====
# 生成命令：openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=change-me-to-another-strong-random-secret
ADMIN_JWT_EXPIRES_IN=1d

# ===== 雨云上游 API =====
# 官方控制台获取：https://app.rainyun.com/dev/api
# 留空或设置为 "mock" 启用 MOCK 模式（本地开发，所有上游操作模拟）
RAINYUN_API_KEY=
RAINYUN_API_BASE=https://api.v2.rainyun.com
RAINYUN_MOCK=false

# ===== 易支付配置 =====
# 在易支付商户后台获取
EPAY_PID=1000
EPAY_KEY=your-epay-merchant-key
EPAY_API_URL=https://your-epay-gateway.com/submit.php
EPAY_NOTIFY_URL=https://your-domain.com/api/payment/epay/notify
EPAY_RETURN_URL=https://your-domain.com/payment/result

# ===== AES 加密密钥（用于加密 SMTP 密码、短信 AccessKey 等敏感字段）=====
# 必须 32 字节长度（生成命令：openssl rand -hex 16，取 32 字符）
AES_SECRET=change-me-32-bytes-aes-secret!!

# ===== 站点信息 =====
SITE_NAME=KeYuCloud
SITE_URL=https://your-domain.com
PANEL_URL=https://app.rainyun.com

# ===== 管理员初始账号（仅首次 seed 生效，后续修改请通过管理后台）=====
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change-me-to-strong-password

# ===== 文件上传 =====
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=10485760

# ===== HTTPS 代理（可选，仅当服务器需通过代理访问阿里云/雨云 API 时配置）=====
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
